{
	"name": "construct3-chef",
	"version": "0.1.0",
	"license": "MIT-0",
	"author": "Genvid Technologies, inc. <support@genvidtech.com>",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"construct3-chef": "./dist/cli.js"
	},
	"exports": {
		".": "./src/index.ts",
		"./mcp": "./src/mcp/server.ts",
		"./sid-utils": "./src/c3/sidUtils.ts"
	},
	"files": [
		"dist",
		"docs",
		"LICENSE",
		"README.md"
	],
	"publishConfig": {
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"./mcp": {
				"types": "./dist/mcp/server.d.ts",
				"default": "./dist/mcp/server.js"
			},
			"./sid-utils": {
				"types": "./dist/c3/sidUtils.d.ts",
				"default": "./dist/c3/sidUtils.js"
			}
		}
	},
	"scripts": {
		"download-deps": "node scripts/download-deps.mjs",
		"build": "tsc && node -e \"const fs=require('fs');const f='dist/cli.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\"",
		"test": "mocha --timeout 5000 --import=tsx --require ./test/setup.ts 'test/**/*.test.ts' --exit",
		"lint": "eslint --ext .ts --max-warnings 0 src/ test/",
		"typecheck": "tsc --noEmit"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"genvid-mcp-utils": "file:.packages/genvid-mcp-utils.tgz",
		"c3source": "file:.packages/c3source.tgz",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"yargs": "^17.7.2",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"mocha": "^10.4.0",
		"chai": "^5.1.1",
		"@types/node": "^22.0.0",
		"@types/mocha": "^10.0.6",
		"@types/chai": "^4.3.16",
		"tsx": "^4.21.0",
		"typescript": "^5.4.5",
		"eslint": "^8.36.0",
		"@typescript-eslint/eslint-plugin": "^7.10.0",
		"@typescript-eslint/parser": "^7.10.0",
		"eslint-config-prettier": "^8.7.0",
		"@types/yargs": "^17.0.33",
		"@types/tmp": "^0.2.6",
		"tmp": "^0.2.3"
	}
}
